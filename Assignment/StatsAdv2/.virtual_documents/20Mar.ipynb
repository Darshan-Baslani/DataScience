














import math
from scipy.stats import norm
import matplotlib.pyplot as plt
import numpy as np


def pdf(x, mean, sd):
    return norm.pdf(x, loc=mean, scale=sd)


mean = 0
sd = 1
x = 1.5
print(f"PDF of {x} with mean: {mean} and standard deviation: {sd} is {pdf(x,mean,sd)}")

# Graph showing pdf for values -5 to 5
x_values = np.linspace(-5, 5)
pdf_values = [pdf(x, mean, sd) for x in x_values]
plt.plot(x_values, pdf_values)
plt.grid()
plt.show()














size = 1000
probability_of_success = 0.4
random_sample = np.random.binomial(n=1, p=probability_of_success, size=size)

plt.xticks([0, 1], ['Failure (0)', 'Success (1)'])
plt.hist(random_sample, bins=2, edgecolor='black')
plt.show()





mean = 0.5
x_poisson = np.linspace(-4, 4, 1000)
poisson_cdf = norm.cdf(x_poisson, mean)

plt.plot(x_poisson, poisson_cdf)
plt.show()











from scipy.stats import poisson

mean = 5
poisson = np.array(np.random.poisson(mean, 1000))
sample_mean = np.mean(poisson)
variance = np.var(poisson)

print(f"Sample Mean : {sample_mean}")
print(f"Variance : {variance}")












